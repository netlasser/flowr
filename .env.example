# FLOWR Environment Variables
# Copy this file to .env and fill in your values.

# App environment (production, beta, development)
VITE_APP_ENV=development

# Beta access control — comma-separated email whitelist (only checked when VITE_APP_ENV=beta)
BETA_EMAIL_WHITELIST=

# Supabase project settings
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# PostgreSQL connection string from Supabase
# Use the connection pooler (port 6543) for the API
# Use the direct connection (port 5432) for migrations
DATABASE_URL=postgresql://<user>:<password>@<host>:6543/postgres

# JWT secret for authentication tokens
JWT_SECRET=<your-secure-random-secret>

# Port for the Express backend (default: 5000)
PORT=5000

# Sentry
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
