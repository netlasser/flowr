# FLOWR Environment Variables
# Copy this file to .env and fill in your values.

# Supabase project settings
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# PostgreSQL connection string from Supabase
# Use the connection pooler (port 6543) for the API
# Use the direct connection (port 5432) for migrations
DATABASE_URL=postgresql://<user>:<password>@<host>:6543/postgres

# Port for the Express backend (default: 5000)
PORT=5000
